{
  "name": "nutribot-pro-vercel",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "tsc && vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/genai": "^1.28.0",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "marked": "^12.0.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vercel/node": "^3.2.3",
    "@vitejs/plugin-react": "^4.3.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.3",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  }
}
